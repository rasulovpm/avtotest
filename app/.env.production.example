# Production environment for avtoimtixon.uz
# Copy this file to `.env.production` on the server and fill in real values.
# DO NOT commit `.env.production` itself — only this template.

# --- Database (SQLite, file lives in the `app-data` Docker volume) ---
# Container path is fixed by docker-compose; the value below is informational.
DATABASE_URL="file:/app/data/prod.db"

# --- NextAuth ---
# Public URL the browser will see (must match what users type, including https when cert is on)
NEXTAUTH_URL="http://157.180.28.98"
# Generate a strong secret:  openssl rand -base64 48
NEXTAUTH_SECRET="REPLACE_WITH_LONG_RANDOM_STRING"

# --- Telegram OTP ---
# Hozircha DEV mode: OTP konsolega chiqadi, real bot kerak emas.
# Productionga o'tganda TELEGRAM_DEV_MODE=false qiling va token+username to'ldiring.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_DEV_MODE="true"

# --- Click (kelajakda) ---
CLICK_SERVICE_ID=""
CLICK_MERCHANT_ID=""
CLICK_SECRET_KEY=""
CLICK_MERCHANT_USER_ID=""

# --- Initial super admin ---
ADMIN_PHONE="+998901234567"

# --- One-time DB seed on first boot? ---
# Set to 1 only on the very first deploy to populate questions/topics.
# After first boot, set back to 0 (or remove) to avoid re-running seeds.
RUN_SEED=0
